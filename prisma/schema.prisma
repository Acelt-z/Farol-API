// I'll make some adaptations and add required fields that aren't in the conceptual database model.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  MEMBER
}

enum CompanyStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PlanType {
  BASIC
  PRO
  PREMIUM
  ENTERPRISE
}

model User {
  id        String @id @default(uuid())
  // "Name" changed
  firstName String
  lastName  String

  email String  @unique
  phone String? @unique

  // CPF added
  cpf String @unique

  password String

  // Verifications
  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  // basic additions
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userCompany UserCompany[]
  companies   Company[]
}

model Plan {
  id           Int       @id @default(autoincrement())
  name         PlanType  @unique
  maxUsers     Int?
  pricePerUser Int
  companies    Company[]
}

model Company {
  id   String @id @default(uuid())
  name String
  cnpj String @unique

  // address fields
  number     Int
  street     String
  city       String
  uf         String
  zipCode    String
  complement String?

  // payment validation
  trialEndsAt DateTime?
  status      CompanyStatus @default(TRIAL)
  plan        Plan?         @relation(fields: [planId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  userCompanyRoles UserCompany[]

  parentCompanyId String?
  parentCompany   Company? @relation("parentCompany", fields: [parentCompanyId], references: [id])

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String
  planId  Int?

  branchCompanies Company[] @relation("parentCompany")
}

model UserCompany {
  id             String  @id @default(uuid())
  companyId      String
  userId         String
  isBillableUser Boolean @default(false)
  role           Role

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@unique([companyId, role, userId])
}
